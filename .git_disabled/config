[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/rohiniwari/RaiseRealm-frontend-.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	github-pr-base-branch = "rohiniwari#RaiseRealm-frontend-#master"
	merge = refs/heads/main
	vscode-merge-base = origin/main
